      "name": "Admin Login",
      "item": [
        {
          "name": "Admin_Login",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "var url = \"http://localhost:5000/\";\r",
                  "var key = \"ROADTOSDET\";\r",
                  "\r",
                  "pm.collectionVariables.set( \"baseurl\" , url );\r",
                  "pm.collectionVariables.set(\"secretKey\" , key)"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json() ;\r",
                  "\r",
                  "pm.test( \"User can login Successfully\" , function(){\r",
                  "    pm.expect( jsonData.message ).to.contains(\"Login successful\")\r",
                  "}   );\r",
                  "\r",
                  "\r",
                  "\r",
                  "\r",
                  "pm.test(\"Status code is 200\" , function(){\r",
                  "    pm.response.to.have.status(200);\r",
                  "}  )\r",
                  "\r",
                  "\r",
                  "var token = jsonData.token;\r",
                  "pm.collectionVariables.set(\"adminToken\" , token)"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
